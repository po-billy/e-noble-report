# ─────────────────────────────────────────────────────────
# ad-report 환경변수 예시 — 복사해서 .env 로 만들고 값 채우기
#   cp .env.example .env
# .env 는 절대 커밋/공유하지 마세요 (키·비밀 포함)
# ─────────────────────────────────────────────────────────

# ── 필수 ──────────────────────────────────────────────────
# Claude API 키 (AI 코멘트 생성)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxx

# 로그인 세션 서명 키 — 반드시 임의의 긴 값으로! (예: openssl rand -hex 32)
SESSION_SECRET=change-this-to-a-long-random-string

# 실 네이버 API 사용: false / 테스트용 가짜데이터: true
NAVER_MOCK=false

# ── 선택: 단일 계정 폴백 (보통 비워둠 — 광고주 키는 웹/시트로 등록) ──
NAVER_API_KEY=
NAVER_API_SECRET=
NAVER_CUSTOMER_ID=
NAVER_ACCOUNT_NAME=

# ── 선택: Google Sheets 를 로스터 원본으로 쓸 때만 ──
# ROSTER_GSHEET_ID=
# ROSTER_GSHEET_TAB=
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
